<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical"
    android:background="#1e1e2e">

    <!-- Apenas a ListView que vai receber os itens do Adapter -->
    <ListView
        android:id="@+id/lvComments"
        android:layout_width="fill_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#2a2a3c"
        android:dividerHeight="1dp" />

    <!-- Area de digitar comentário no rodape -->
    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:background="#181825">

        <EditText
            android:id="@+id/commentEdt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Comment..."
            android:textColor="#cdd6f4"
            android:textSize="13sp"
            android:singleLine="true" />

        <Button
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Send"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>