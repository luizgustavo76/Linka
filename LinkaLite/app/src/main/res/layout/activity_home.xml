<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1e1e2e">

    <!-- Botão de novo post no topo para não atrapalhar o scroll -->
    <Button 
        android:id="@+id/newPost"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:text="+ New Post"
        android:textSize="13sp"
        android:layout_margin="4dp" />

    <!-- O ListView ocupando a tela central -->
    <ListView
        android:id="@+id/listViewPosts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollingCache="false"   
        android:divider="#2a2a3c"
        android:dividerHeight="1dp" />

    <!-- Menu Inferior Enxuto (40dp) -->
    <LinearLayout 
        android:layout_width="match_parent"
        android:layout_height="40dp" 
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#11111b">

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/home"
            android:scaleType="centerInside"
            android:background="@android:color/transparent"
            android:contentDescription="home" />

        <ImageButton
            android:id="@+id/btnChat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/chat"
            android:scaleType="centerInside"
            android:background="@android:color/transparent"
            android:contentDescription="Chat" />

        <ImageButton
            android:id="@+id/btnOptions"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/options"
            android:scaleType="centerInside"
            android:background="@android:color/transparent"
            android:contentDescription="Options" />

        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/account"
            android:scaleType="centerInside"
            android:background="@android:color/transparent"
            android:contentDescription="Profile" />

    </LinearLayout>

</LinearLayout>